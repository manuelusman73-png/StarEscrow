# StarEscrow CLI Environment Variables
# Copy this file to .env and fill in the values

# Contract ID (required for all CLI operations)
ESCROW_CONTRACT_ID=

# Secret key for the payer account (used for create, approve, cancel, expire commands)
PAYER_SECRET=

# Secret key for the freelancer account (used for submit_work, transfer_freelancer commands)
FREELANCER_SECRET=

# Secret key for the admin account (used for init, pause, unpause commands)
ADMIN_SECRET=

# Secret key for the deployer account (used for deploy command)
DEPLOYER_SECRET=

# Optional: RPC URL (defaults to https://soroban-testnet.stellar.org)
# RPC_URL=https://soroban-testnet.stellar.org

# Optional: Network passphrase (defaults to "Test SDF Network ; September 2015")
# NETWORK_PASSPHRASE=Test SDF Network ; September 2015
